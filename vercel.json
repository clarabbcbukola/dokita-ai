{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/admin/verify", "dest": "/api/admin/verify.js" },
    { "src": "/api/admin/books", "dest": "/api/admin/books.js" },
    { "src": "/api/admin/index-book", "dest": "/api/admin/index-book.js" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/analyze-image", "dest": "/api/analyze-image.js" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/admin.html", "dest": "/public/admin.html" },
    { "src": "/manifest.json", "dest": "/public/manifest.json" },
    { "src": "/sw.js", "dest": "/public/sw.js" },
    { "src": "/icons/(.*)", "dest": "/public/icons/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
